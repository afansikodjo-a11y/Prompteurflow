# Copiez ce fichier en `.env.local` puis renseignez vos valeurs.
# Les variables exposées au client doivent être préfixées par NEXT_PUBLIC_.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (auth + base de données) — Réglages du projet > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service-role : contourne la RLS, jamais exposée au client (pas de préfixe NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=

# Moneroo (paiement) — clés secrètes, jamais exposées au client
MONEROO_SECRET_KEY=
MONEROO_WEBHOOK_SECRET=
